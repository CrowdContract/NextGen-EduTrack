{
  "name": "nextgen-edutrack",
  "version": "1.0.0",
  "description": "A comprehensive Final Year Project Management System",
  "main": "server/server.js",
  "type": "module",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "client": "cd client && npm run dev",
    "server": "cd server && npm run dev",
    "dev:all": "concurrently \"npm run server\" \"npm run client\"",
    "install:all": "npm install && cd client && npm install && cd ../server && npm install",
    "build": "cd client && npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "education",
    "project-management",
    "fyp",
    "university",
    "react",
    "nodejs",
    "mongodb"
  ],
  "author": "CrowdContract Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CrowdContract/NextGen-EduTrack.git"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-fileupload": "^1.5.2",
    "express-rate-limit": "^8.3.1",
    "groq-sdk": "^1.1.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.23.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
